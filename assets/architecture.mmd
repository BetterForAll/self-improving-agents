%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '14px'}}}%%
graph LR
    subgraph L4["Level 4: Arena Loop"]
        direction LR
        LLM4[LLM x4] -->|proposes| Code4[Code]
        Test4[Test Agents] -->|write harder tests| Bench4[Benchmark]
        Code4 -->|runs| Bench4
        Bench4 -->|tournament selection| LLM4
    end

    subgraph L3["Level 3: HyperAgent"]
        direction LR
        LLM3[LLM] -->|proposes| Code3[Code]
        Code3 -->|runs| Bench3[Benchmark]
        Bench3 -->|results| Meta3[Meta Agent]
        Meta3 -.->|rewrites agent source code| LLM3
    end

    subgraph L2["Level 2: Feedback Loop"]
        direction LR
        LLM2[LLM] -->|proposes| Code2[Code]
        Code2 -->|runs| Bench2[Benchmark]
        Bench2 -->|results| Reviewer2[Reviewer]
        Reviewer2 -->|WHY + fix suggestions| LLM2
    end

    subgraph L1["Level 1: AutoResearch"]
        direction LR
        LLM1[LLM] -->|proposes| Code1[Code]
        Code1 -->|runs| Bench1[Benchmark]
        Bench1 -->|keep/revert| LLM1
    end

    style L1 fill:#fce4ec,stroke:#c62828
    style L2 fill:#e8f5e9,stroke:#2e7d32
    style L3 fill:#e3f2fd,stroke:#1565c0
    style L4 fill:#f3e5f5,stroke:#6a1b9a

